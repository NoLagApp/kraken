{erl_opts, [debug_info]}.

{deps, [
    {cowboy, "2.10.0"},
    {gun, "2.1.0"},
    {jsx, "3.1.0"},
    {msgpack, "0.7.0"},
    {emqtt, "1.10.0"},  % MQTT client — used by the kraken_broker_mqtt adapter
    {syn, "3.3.0"}      % Process registry — presence + the default syn broker
]}.

%% NOTE: the release version below is a placeholder — rebar.config.script
%% overwrites it with the {vsn,...} from src/kraken.app.src, the single source
%% of truth for the version. Bump the version in src/kraken.app.src only.
{relx, [
    {release, {kraken, "0-from-app-src"},
        [
            inets,
            ssl,
            gun,
            syn,
            kraken,
            sasl
        ]},
    {dev_mode, true},
    {include_erts, false},
    {extended_start_script, true},
    {sys_config_src, "./config/sys.config.src"},
    {vm_args_src, "./config/vm.args.src"}
]}.

{profiles, [
    {prod, [
        {relx, [
            {dev_mode, false},
            {include_erts, true},
            {mode, prod}
        ]}
    ]}
]}.

{shell, [
    {apps, [kraken]}
]}.
