[
  {kraken, [
    {ws_port, 8090},
    {mqtt_port, 18883},
    {auth_backend, kraken_auth_e2e},
    {broker_backend, syn},
    {presence_store_backend, kraken_presence_store_ets},
    {wake_backend, kraken_wake_http},
    {wake_secret, "e2e-secret"},
    %% Durable delivery (claim-based replay for load-balanced workers).
    %% record_messages populates the message store that replay reads from.
    {store_backend, ets},
    {record_messages, true},
    {delivery_store_backend, kraken_delivery_store_ets},
    {durable_delivery, true}
  ]}
].
